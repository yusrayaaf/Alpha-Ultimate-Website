# ═══════════════════════════════════════════════════════════════════════════
#  ALPHA ULTIMATE — Environment Variables Reference
#  Run DEPLOY.sh — it sets all of these automatically in Vercel
#  For local dev: copy this to .env and fill in values
# ═══════════════════════════════════════════════════════════════════════════

# ─── ADMIN LOGIN ─────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMe_UseStrongPassword!

# Auto-generated by DEPLOY.sh:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_string

# ─── IONOS EMAIL (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=reply@alpha-01.com
SMTP_PASS=your_ionos_email_password_here
EMAIL_FROM=reply@alpha-01.com
EMAIL_INFO=info@alpha-01.com

# ─── DATABASE (NeonDB — free at neon.tech) ───────────────────────────────────
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# ─── IMAGE UPLOADS (free — imgbb.com/api) ────────────────────────────────────
IMGBB_API_KEY=your_imgbb_api_key

# ─── AI CHATBOT (free — openrouter.ai) ───────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# ─── TELEGRAM NOTIFICATIONS (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ─── CONTENT BACKUP (optional — jsonbin.io) ──────────────────────────────────
JSONBIN_BIN_ID=xxxxxxxxxxxxxx
JSONBIN_API_KEY=$2b$10$xxxxxxxxxxxxxxxxxxxxx
